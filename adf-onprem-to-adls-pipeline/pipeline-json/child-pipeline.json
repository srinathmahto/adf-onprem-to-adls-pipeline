{
    "name": "PL_Child_Worker",
    "properties": {
        "activities": [
            {
                "name": "Copy_Data_To_ADLS",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "7.00:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": {
                            "value": "@if(equals(pipeline().parameters.LoadType, 'Full'), concat('SELECT * FROM ', pipeline().parameters.SourceSchemaName, '.', pipeline().parameters.SourceTableName), concat('SELECT * FROM ', pipeline().parameters.SourceSchemaName, '.', pipeline().parameters.SourceTableName, ' WHERE ', pipeline().parameters.WatermarkColumn, ' > ''', pipeline().parameters.LastWatermarkValue, ''''))",
                            "type": "Expression"
                        },
                        "queryTimeout": "02:00:00",
                        "partitionOption": "None"
                    },
                    "sink": {
                        "type": "ParquetSink",
                        "storeSettings": {
                            "type": "AzureBlobFSWriteSettings"
                        },
                        "formatSettings": {
                            "type": "ParquetWriteSettings"
                        }
                    },
                    "enableStaging": false
                },
                "inputs": [
                    {
                        "referenceName": "DS_Source_SQLServer",
                        "type": "DatasetReference",
                        "parameters": {
                            "SchemaName": {
                                "value": "@pipeline().parameters.SourceSchemaName",
                                "type": "Expression"
                            },
                            "TableName": {
                                "value": "@pipeline().parameters.SourceTableName",
                                "type": "Expression"
                            }
                        }
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "DS_Sink_ADLS",
                        "type": "DatasetReference",
                        "parameters": {
                            "ContainerName": {
                                "value": "@pipeline().parameters.TargetContainerName",
                                "type": "Expression"
                            },
                            "DirectoryPath": {
                                "value": "@pipeline().parameters.TargetDirectoryPath",
                                "type": "Expression"
                            },
                            "FileName": {
                                "value": "@concat(pipeline().parameters.SourceTableName, '_', formatDateTime(utcnow(), 'yyyyMMdd_HHmmss'), '.parquet')",
                                "type": "Expression"
                            }
                        }
                    }
                ]
            },
            {
                "name": "Execute_Update_Watermark",
                "type": "ExecutePipeline",
                "dependsOn": [
                    {
                        "activity": "Copy_Data_To_ADLS",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "userProperties": [],
                "typeProperties": {
                    "pipeline": {
                        "referenceName": "PL_Update_Watermark",
                        "type": "PipelineReference"
                    },
                    "waitOnCompletion": true,
                    "parameters": {
                        "SourceSchemaName": {
                            "value": "@pipeline().parameters.SourceSchemaName",
                            "type": "Expression"
                        },
                        "SourceTableName": {
                            "value": "@pipeline().parameters.SourceTableName",
                            "type": "Expression"
                        },
                        "NewWatermarkValue": {
                            "value": "@pipeline().TriggerTime",
                            "type": "Expression"
                        }
                    }
                }
            }
        ],
        "parameters": {
            "SourceSchemaName": {
                "type": "string"
            },
            "SourceTableName": {
                "type": "string"
            },
            "TargetContainerName": {
                "type": "string"
            },
            "TargetDirectoryPath": {
                "type": "string"
            },
            "LoadType": {
                "type": "string"
            },
            "WatermarkColumn": {
                "type": "string"
            },
            "LastWatermarkValue": {
                "type": "string"
            }
        },
        "annotations": []
    }
}
